# =============================================================
# RealTimeGuard — .gitignore
# =============================================================

# =============================================================
# Python
# =============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# Virtual environments
venv/
.venv/
env/
ENV/

# pip
pip-log.txt
pip-delete-this-directory.txt

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST

# Type checking / linting caches
.mypy_cache/
.ruff_cache/
.pyrefly/

# =============================================================
# Pytest / Coverage
# =============================================================
.pytest_cache/
.coverage
.coverage.*
coverage/
htmlcov/

# =============================================================
# Jupyter
# =============================================================
.ipynb_checkpoints/
ml-service/notebooks/

# =============================================================
# ML Artifacts — large binary files, always regenerable
# =============================================================

# Trained models (large binary blobs — regenerate with train.py)
ml-service/models/*.pkl
ml-service/models/*.joblib
ml-service/models/*.h5
ml-service/models/*.onnx

# Keep JSON metadata — small, human-readable, version-meaningful
!ml-service/models/*.json

# =============================================================
# Dataset — large CSV files (up to 534 MB)
# =============================================================
ml-service/data/raw/
ml-service/data/processed/

# =============================================================
# Generated Reports — regenerable from train.py
# =============================================================
ml-service/reports/

# =============================================================
# Logs
# =============================================================
*.log
ml-service/logs/

# =============================================================
# Environment Variables — NEVER commit secrets
# =============================================================
.env
.env.local
.env.development
.env.production
.env.*.local

# =============================================================
# Node.js / Frontend (for future phases)
# =============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn/

# =============================================================
# Docker
# =============================================================
docker-compose.override.yml

# =============================================================
# Databases
# =============================================================
*.sqlite3
*.db

# =============================================================
# OS / Editor junk
# =============================================================
.DS_Store
Thumbs.db
desktop.ini

# IDEs
.vscode/
.idea/
*.swp
*.swo

# =============================================================
# Misc
# =============================================================
*.tmp
*.bak
.eslintcache